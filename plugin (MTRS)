import json
import re
from typing import List
from swift.plugin import ORM, orms

def extract_array(text: str):
    m = re.search(r'\[.*?\]', text, re.S)
    if not m:
        raise ValueError("No array in text")
    return json.loads(m.group(0))

def has_natural_language(text: str) -> bool:
    return bool(re.search(r'[\u4e00-\u9fa5]', text))

def get_ground_truth(solution, kwargs):
    if solution is not None:
        return solution  
    for key in ['labels', 'solution', 'label', 'ground_truth', 'gt', 'answer']:
        if key in kwargs and kwargs[key] is not None:
            return kwargs[key]
    return None

class TSFormatORM(ORM):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.w_f = ()

    def __call__(self, completions, solution=None, **kwargs) -> List[float]:
        rewards = []
        for comp in completions:
            try:
                if has_natural_language(comp):
                    rewards.append(-5.0 * self.w_f)
                    continue
                
                y_pred = extract_array(comp)
                if isinstance(y_pred, list) and len(y_pred) > 0:
                    rewards.append(0.0 * self.w_f)
                else:
                    rewards.append(-5.0 * self.w_f)
            except Exception:
                rewards.append(-5.0 * self.w_f)     
        return rewards

class TSLengthORM(ORM):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.w_l = ()

    def __call__(self, completions, solution=None, **kwargs) -> List[float]:
        ground_truth = get_ground_truth(solution, kwargs)
        if ground_truth is None:
            return [0.0] * len(completions)
        
        rewards = []
        for comp, gt in zip(completions, ground_truth):
            try:
                y_pred = extract_array(comp)
                if isinstance(gt, str):
                    y_true = json.loads(gt)
                else:
                    y_true = gt
                    
                len_true = len(y_true)
                len_pred = len(y_pred)
                
                if len_true == 0:
                    rewards.append(0.0)
                    continue

                if len_pred >= len_true:
                    rewards.append((1.0 - (len_pred / len_true)) * self.w_l) 
                else:
                    rewards.append(((len_pred / len_true) - 1.0) * self.w_l)               
            except Exception:
                rewards.append(0.0)        
        return rewards

class TSMSEORM(ORM):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.w_m = ()

    def __call__(self, completions, solution=None, **kwargs) -> List[float]:
        ground_truth = get_ground_truth(solution, kwargs)
        if ground_truth is None:
            return [0.0] * len(completions)
            
        rewards = []
        for comp, gt in zip(completions, ground_truth):
            try:
                y_pred = extract_array(comp)
                if isinstance(gt, str):
                    y_true = json.loads(gt)
                else:
                    y_true = gt
                
                if (not isinstance(y_true, list) or
                    not isinstance(y_pred, list) or
                    len(y_true) != len(y_pred) or
                    len(y_true) == 0):
                    rewards.append(0.0)
                    continue
                
                se = 0.0
                for p, t in zip(y_pred, y_true):
                    se += (float(p) - float(t)) ** 2
                mse = se / len(y_true)
                
                rewards.append(-mse * self.w_m)
                
            except Exception:
                rewards.append(0.0)
        return rewards

orms["ts_format"] = TSFormatORM
orms["ts_length"] = TSLengthORM
orms["ts_mse"] = TSMSEORM
