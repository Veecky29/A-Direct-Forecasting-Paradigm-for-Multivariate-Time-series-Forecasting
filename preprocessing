        horizon=HORIZON,
        stride=STRIDE,
        fmt=FLOAT_FORMAT
    )
    
    n_total = len(samples)
    
    n_train = int(n_total * TRAIN_RATIO)
    train_samples = samples[:n_train]
    test_samples = samples[n_train:]

    out_train_path = f"{OUT_PREFIX}_multivariate_train.jsonl"
    out_test_path = f"{OUT_PREFIX}_multivariate_test.jsonl"
    
    Path(out_train_path).parent.mkdir(parents=True, exist_ok=True)
    
    with open(out_train_path, "w", encoding="utf-8") as f:
        for s in train_samples:
            f.write(json.dumps(s, ensure_ascii=False) + "\n")
            
    with open(out_test_path, "w", encoding="utf-8") as f:
        for s in test_samples:
            f.write(json.dumps(s, ensure_ascii=False) + "\n")

if __name__ == "__main__":
    main()
