FLOAT_FORMAT = "%.3f"
# ======================================================================

def format_float(v, fmt="%.3f"):
    try:
        return fmt % float(v)
    except:
        return str(v)

def build_samples_from_revin_xlsx(df, time_col, feature_cols, lookback, horizon, stride, fmt="%.3f"):
    total_len = len(df)
    samples = []
    
    time_arr = df[time_col].astype(str).values
    feat_arr = df[feature_cols].values

    for start_idx in range(0, total_len - lookback - horizon + 1, stride):

        hist_end_idx = start_idx + lookback
        hist_time = time_arr[start_idx:hist_end_idx]
        hist_data = feat_arr[start_idx:hist_end_idx]

        tgt_end_idx = hist_end_idx + horizon
        tgt_time = time_arr[hist_end_idx:tgt_end_idx]
        tgt_data = feat_arr[hist_end_idx:tgt_end_idx]
        
        context_lines = []
        for t, row in zip(hist_time, hist_data):
            row_str = " ".join([format_float(v, fmt) for v in row])
            context_lines.append(f"{t} {row_str}")
        context_block = "\n".join(context_lines)
        

        response_lines = []
        for row in tgt_data:
            row_str = " ".join([format_float(v, fmt) for v in row])
            response_lines.append(row_str)
        response_block = "\n".join(response_lines)

        hist_start_ts = time_arr[start_idx]
        hist_end_ts = time_arr[hist_end_idx - 1]
        tgt_start_ts = time_arr[hist_end_idx]
        tgt_end_ts = time_arr[tgt_end_idx - 1]

        sample = {
            "system": (
                "You are a time series forecasting assistant. Based on the context provided by the user, output only the prediction results without explanation. Requirements: Output only a sequence of real numbers, separated by spaces. No other text or punctuation is allowed."
            ),
            "user": f"[Context (Normalized data):\n{context_block}]",
            "assistant": f"[{response_block}]",
            "meta": {
                "hist_start": hist_start_ts,
                "hist_end": hist_end_ts,
                "tgt_start": tgt_start_ts,
                "tgt_end": tgt_end_ts,
                "num_variables": len(feature_cols)
            }
        }
        
        samples.append(sample)
    
    return samples

