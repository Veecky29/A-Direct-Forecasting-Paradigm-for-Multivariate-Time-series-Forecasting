swift rlhf \
  --rlhf_type grpo \
  --model Qwen/Qwen2.5-0.5B-Instruct \
  --model_type qwen2_5 \
  --adapters /use check point here \
  --train_type lora \
  --external_plugins /plugin.py \
  --reward_funcs ts_mse \
  --use_vllm true \
  --vllm_mode colocate \
  --vllm_gpu_memory_utilization 0.5 \
  --vllm_max_model_len 4096 \
  --torch_dtype bfloat16 \
  --dataset /enter data after filtering here \
  --load_from_cache_file true \
  --max_completion_length 512 \
  --num_train_epochs 10 \
  --per_device_train_batch_size 2 \
  --per_device_eval_batch_size 2 \
  --learning_rate 1e-6 \
  --gradient_accumulation_steps 2 \
  --eval_steps 200 \
  --save_steps 200 \
  --save_total_limit 2 \
  --logging_steps 5 \
  --max_length 4096 (changeable, or set a very large value, such as 296000) \
  --output_dir /output path \
  --warmup_ratio 0.05 \
  --dataloader_num_workers 4 \
  --dataset_num_proc 4 \
  --num_generations 8 \
  --generation_batch_size 8 \
  --temperature 0.9 \
  --log_completions true
